<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme.
        Inherits from Material3 DayNight so the app automatically supports
        light / dark mode without any extra work.
    -->
    <style name="Theme.HomeMonitor" parent="Theme.MaterialComponents.DayNight.DarkActionBar">

        <!-- Primary brand colour -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Accent / secondary colour -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar colour -->
        <item name="android:statusBarColor">@color/primary_dark</item>

    </style>

</resources>
